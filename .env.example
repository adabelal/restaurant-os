# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/restaurant_os?schema=public"

# NextAuth.js - OBLIGATOIRE
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="votre_secret_ici_generer_avec_openssl"

# URL de l'application (pour les redirections)
NEXTAUTH_URL="http://localhost:3000"

# API Resend pour l'envoi d'emails (optionnel)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# API N8N pour les webhooks (optionnel)
N8N_API_KEY="votre_cle_api_n8n"

# API Jules pour l'automatisation de tâches de développement
JULES_API_KEY="votre_cle_api_jules"


# Easypanel Log Integration
EASYPANEL_URL="https://votre-easypanel-url.com"
EASYPANEL_API_KEY="votre_server_api_key"
