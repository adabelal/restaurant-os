generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  password             String
  name                 String
  firstName            String?
  lastName             String?
  role                 Role               @default(STAFF)
  hourlyRate           Decimal            @default(11.52) @db.Decimal(10, 2)
  phone                String?
  address              String?
  isActive             Boolean            @default(true)
  contractType         String?            @default("CDI")
  contractDuration     String?            @default("FULL_TIME")
  resetPasswordToken   String?            @unique
  resetPasswordExpires DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  cashTransactions     CashTransaction[]
  documents            EmployeeDocument[]
  haccpLogs            HaccpLog[]
  shifts               Shift[]
  stockLogs            StockMovement[]
  monthlySalaries      MonthlySalary[]
}

model MonthlySalary {
  id              String   @id @default(cuid())
  userId          String
  month           Int
  year            Int
  netRemuneration Decimal? @db.Decimal(10, 2)
  bankPaid        Decimal? @default(0) @db.Decimal(10, 2)
  status          String   @default("PENDING") // PENDING, PARTIAL, COMPLETED, OVERPAID
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model EmployeeDocument {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  category  String   @default("OTHER")
  url       String
  month     Int?
  year      Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Shift {
  id           String    @id @default(cuid())
  userId       String
  startTime    DateTime
  endTime      DateTime?
  breakMinutes Int       @default(0)
  isSunday     Boolean   @default(false)
  isNight      Boolean   @default(false)
  hourlyRate   Decimal   @db.Decimal(10, 2)
  status       String    @default("COMPLETED")
  notes        String?
  position     String?
  user         User      @relation(fields: [userId], references: [id])
}

model Supplier {
  id          String          @id @default(cuid())
  name        String          @unique
  email       String?
  phone       String?
  address     String?
  ingredients Ingredient[]
  purchases   PurchaseOrder[]
}

model Ingredient {
  id           String             @id @default(cuid())
  name         String
  category     String
  currentStock Decimal            @default(0)
  unit         Unit               @default(KG)
  minStock     Decimal            @default(0)
  pricePerUnit Decimal            @db.Decimal(10, 4)
  supplierId   String?
  allergens    String[]
  lastBatchNo  String?
  lastDLC      DateTime?
  updatedAt    DateTime           @updatedAt
  supplier     Supplier?          @relation(fields: [supplierId], references: [id])
  invoiceItems InvoiceItem[]
  inRecipes    RecipeIngredient[]
  movements    StockMovement[]
}

model Recipe {
  id           String             @id @default(cuid())
  name         String
  category     String
  salePrice    Decimal            @db.Decimal(10, 2)
  vatRate      Decimal            @default(10.0)
  instructions String?
  foodCost     Decimal?           @db.Decimal(10, 2)
  margin       Decimal?           @db.Decimal(10, 2)
  isActive     Boolean            @default(true)
  ingredients  RecipeIngredient[]
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Decimal    @db.Decimal(10, 3)
  unit         Unit
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
}

model StockMovement {
  id           String       @id @default(cuid())
  ingredientId String
  userId       String
  type         MovementType
  quantity     Decimal
  reason       String?
  createdAt    DateTime     @default(now())
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model PurchaseOrder {
  id               String            @id @default(cuid())
  supplierId       String?
  date             DateTime          @default(now())
  invoiceNo        String?
  totalAmount      Decimal           @default(0) @db.Decimal(10, 2)
  status           InvoiceStatus     @default(DRAFT)
  scannedUrl       String?
  paymentMethod    String?
  deliveryMode     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bankTransactions BankTransaction[]
  items            InvoiceItem[]
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])

  @@index([date])
}

model InvoiceItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  rawLabel        String
  ingredientId    String?
  quantity        Decimal       @db.Decimal(10, 3)
  unitPrice       Decimal       @db.Decimal(10, 4)
  totalPrice      Decimal       @db.Decimal(10, 2)
  priceVariation  Decimal?      @db.Decimal(5, 2)
  packaging       String?
  createdAt       DateTime      @default(now())
  ingredient      Ingredient?   @relation(fields: [ingredientId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model HaccpLog {
  id          String   @id @default(cuid())
  userId      String
  type        LogType
  value       String?
  targetName  String
  isCompliant Boolean  @default(true)
  photoUrl    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model CashTransaction {
  id          String              @id @default(cuid())
  date        DateTime            @default(now())
  amount      Decimal             @db.Decimal(10, 2)
  type        CashTransactionType
  description String
  categoryId  String?
  userId      String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  category    FinanceCategory?    @relation(fields: [categoryId], references: [id])
  user        User?               @relation(fields: [userId], references: [id])

  @@index([date])
}

model CashCategory {
  id        String              @id @default(cuid())
  name      String
  type      CashTransactionType
  color     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([name, type])
}

model AppSettings {
  id              String   @id @default("global")
  accountantEmail String?
  updatedAt       DateTime @updatedAt
}

model FinanceCategory {
  id                  String               @id @default(cuid())
  name                String               @unique
  type                FinanceCategoryType
  description         String?
  color               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  transactions        BankTransaction[]
  budgetGoals         BudgetGoal[]
  cashTransactions    CashTransaction[]
  categorizationRules CategorizationRule[]
  fixedCosts          FixedCost[]
}

model CategorizationRule {
  id         String          @id @default(cuid())
  matchType  String          @default("CONTAINS")
  keyword    String
  categoryId String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  category   FinanceCategory @relation(fields: [categoryId], references: [id])

  @@unique([keyword, matchType])
}

model BankTransaction {
  id              String           @id @default(cuid())
  date            DateTime
  amount          Decimal          @db.Decimal(10, 2)
  description     String
  reference       String?
  status          String           @default("PENDING")
  purchaseOrderId String?
  categoryId      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  paymentMethod   String?
  thirdPartyName  String?
  transactionType String?
  category        FinanceCategory? @relation(fields: [categoryId], references: [id])
  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])

  @@index([date])
}

model FixedCost {
  id         String          @id @default(cuid())
  name       String
  amount     Decimal         @db.Decimal(10, 2)
  dayOfMonth Int
  frequency  String          @default("MONTHLY")
  categoryId String
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  category   FinanceCategory @relation(fields: [categoryId], references: [id])
}

model BudgetGoal {
  id           String          @id @default(cuid())
  month        Int
  year         Int
  categoryId   String
  targetAmount Decimal         @db.Decimal(10, 2)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  category     FinanceCategory @relation(fields: [categoryId], references: [id])

  @@unique([month, year, categoryId])
}

model MusicBand {
  id          String       @id @default(cuid())
  name        String       @unique
  genre       String?
  contact     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  description String?
  email       String?
  phone       String?
  events      MusicEvent[]
}

model MusicEvent {
  id            String    @id @default(cuid())
  bandId        String
  date          DateTime
  startTime     String?
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String    @default("TRANSFER")
  invoiceStatus String    @default("PENDING")
  status        String    @default("SCHEDULED")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isFree        Boolean   @default(false)
  invoiceUrl    String?
  band          MusicBand @relation(fields: [bandId], references: [id])
}

model BankAccount {
  id                     String    @id @default(cuid())
  accountUid             String    @unique
  aspspName              String?
  accountName            String?
  currency               String    @default("EUR")
  enableBankingSessionId String?
  lastSyncedAt           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model ProcessedMail {
  id        String   @id @default(cuid())
  messageId String   @unique
  subject   String
  sender    String
  date      DateTime
  type      String
  status    String   @default("SUCCESS")
  amount    Decimal? @db.Decimal(10, 2)
  targetId  String?
  fileUrl   String?
  fileName  String?

  @@index([date])
}

model MusicBandProposal {
  id              String   @id @default(cuid())
  bandName        String
  style           String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  fullDescription String?
  emailDate       DateTime
  messageId       String   @unique
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  videoLinks      String[] @default([])

  @@index([emailDate])
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum Unit {
  KG
  G
  L
  CL
  ML
  PIECE
}

enum MovementType {
  PURCHASE
  USAGE
  WASTE
  ADJUSTMENT
}

enum InvoiceStatus {
  DRAFT
  PROCESSING
  VALIDATED
  ALERT
}

enum LogType {
  TEMPERATURE_FRIDGE
  TEMPERATURE_FREEZER
  TEMPERATURE_DELIVERY
  CLEANING
  OIL_CHANGE
}

enum CashTransactionType {
  IN
  OUT
}

enum FinanceCategoryType {
  FIXED_COST
  VARIABLE_COST
  REVENUE
  TAX
  FINANCIAL
  INVESTMENT
  SALARY
  INTERNAL_TRANSFER
  TRANSIT
}


enum InvoiceProcessingStatus {
  PENDING
  PROCESSED
  TO_VALIDATE
  ERROR
}

model Invoice {
  id                 String   @id @default(cuid())
  date               DateTime
  supplierName       String
  amount             Decimal  @db.Decimal(10, 2)
  driveFileId        String?
  driveWebViewUrl    String?
  isSentToAccountant Boolean  @default(false)
  status             InvoiceProcessingStatus @default(PROCESSED)
  originalFileName   String?
  errorMessage       String?

  // Champs enrichis V2
  invoiceNumber      String?
  dueDate            DateTime?
  supplierSiret      String?
  supplierAddress    String?
  amountHT           Decimal?  @db.Decimal(10, 2)
  vatRate            Decimal?  @db.Decimal(5, 2)
  vatAmount          Decimal?  @db.Decimal(10, 2)
  paymentMethod      String?
  paymentReference   String?
  confidence         Decimal?  @db.Decimal(3, 2)
  lineItems          Json?

  // Vector Embeddings (768 dimensions pour Gemini 2.0)
  // Stocké en JSON faute d'extension pgvector sur le serveur
  embedding          Json?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([date])
  @@index([supplierName])
  @@index([status])
}
